# OpenAI API (for Whisper fallback, optional)
SMF_OPENAI_API_KEY=

# Anthropic Claude API
SMF_ANTHROPIC_API_KEY=

# LLM Configuration
SMF_LLM_MODEL=claude-opus-4-6
SMF_TEMPERATURE=0.7

# Transcription Configuration
SMF_ENABLE_WHISPER_FALLBACK=false
SMF_ENABLE_CLAUDE_TRANSCRIPTION=true

# Directory for temporary files
SMF_TEMP_DIR=./tmp

# Logging
SMF_LOG_LEVEL=INFO
