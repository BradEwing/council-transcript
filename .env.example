# OpenAI API (for Whisper fallback, optional)
OPENAI_API_KEY=

# Anthropic Claude API
ANTHROPIC_API_KEY=

# LLM Configuration
LLM_MODEL=claude-opus-4-6
TEMPERATURE=0.7

# Transcription Configuration
ENABLE_WHISPER_FALLBACK=false
ENABLE_CLAUDE_TRANSCRIPTION=true

# Directory for temporary files
TEMP_DIR=./tmp

# Logging
LOG_LEVEL=INFO
